---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <p class="font-mono text-sm mb-2" style="color: var(--accent)">// experience</p>
            <h2 class="text-3xl sm:text-4xl md:text-4xl xl:text-5xl font-bold text-gray-900 dark:text-gray-100">
              Experience
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style="background-color: var(--accent)"
            />
          </div>

          <div class="lg:col-span-8">
            <div class="relative">
              {siteConfig.experience.map((exp, index) => (
                <div class="relative mb-12 last:mb-0">
                  {/* Timeline dot at top of card */}
                  <div
                    class="absolute left-1/2 -top-2 w-4 h-4 border-2 rounded-full -translate-x-1/2 z-20 transition-all duration-300"
                    style="border-color: var(--accent); background-color: var(--accent)"
                  />

                  {/* Connecting line below card */}
                  {index < siteConfig.experience.length - 1 && (
                    <div class="absolute left-1/2 bottom-0 w-0.5 h-12 bg-gray-300 dark:bg-gray-700 -translate-x-1/2 translate-y-full z-10" />
                  )}

                  {/* Experience card */}
                  <div class="bg-white dark:bg-gray-900 rounded-lg shadow-sm border border-gray-100 dark:border-gray-800 p-4 sm:p-5 md:p-6 hover:shadow-md dark:hover:border-gray-700 transition-all duration-300">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4">
                      <div>
                        <h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-gray-100">
                          {exp.title}
                        </h3>
                        <p
                          class="text-base sm:text-lg"
                          style="color: var(--accent)"
                        >
                          {exp.url ? (
                            <a
                              href={exp.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="hover:underline"
                            >
                              {exp.company}
                            </a>
                          ) : (
                            exp.company
                          )}
                        </p>
                      </div>
                      <span class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 mt-2 sm:mt-0">
                        {exp.dateRange}
                      </span>
                    </div>

                    <ul class="space-y-2">
                      {exp.bullets.slice(0, 4).map((bullet) => (
                        <li class="flex items-start">
                          <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 dark:bg-gray-600 mt-2 mr-3 flex-shrink-0" />
                          <span class="text-sm sm:text-base text-gray-600 dark:text-gray-400">
                            {bullet}
                          </span>
                        </li>
                      ))}
                    </ul>
                    {exp.bullets.length > 4 && (
                      <details class="group mt-2">
                        <summary
                          class="cursor-pointer list-none text-sm font-medium select-none hover:underline"
                          style="color: var(--accent)"
                        >
                          <span class="group-open:hidden">
                            + {exp.bullets.length - 4} more highlights
                          </span>
                          <span class="hidden group-open:inline">
                            − Show less
                          </span>
                        </summary>
                        <ul class="space-y-2 mt-2">
                          {exp.bullets.slice(4).map((bullet) => (
                            <li class="flex items-start">
                              <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 dark:bg-gray-600 mt-2 mr-3 flex-shrink-0" />
                              <span class="text-sm sm:text-base text-gray-600 dark:text-gray-400">
                                {bullet}
                              </span>
                            </li>
                          ))}
                        </ul>
                      </details>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
