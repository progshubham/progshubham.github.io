---
import { siteConfig } from "../config";

const username = siteConfig.social.github.split("/").pop() ?? "progshubham";
const START_YEAR = 2023;
---

<section
  id="github"
  aria-label="GitHub Contributions by Shubham Kumar Rohit"
  class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-100/60 dark:bg-gray-900/40"
>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <p class="text-sm mb-2" style="color: var(--accent)">// github</p>
        <h2 class="text-3xl sm:text-4xl md:text-4xl xl:text-5xl font-bold text-gray-900 dark:text-gray-100">
          GitHub Contributions
        </h2>
        <div
          class="w-[75px] h-[5px] mt-2 rounded-full"
          style="background-color: var(--accent)"
        ></div>
        <p class="mt-4 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
          Year-by-year view of my open-source and private code activity on
          GitHub — commits, pull requests, reviews, and issue contributions.
        </p>
      </div>

      <div id="github-graphs" class="lg:col-span-8 space-y-10">
        <!-- Loading skeleton -->
        <div class="flex items-center justify-center py-16 text-gray-400 dark:text-gray-500">
          Loading contributions…
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ username, START_YEAR, name: siteConfig.name }}>
  // CSS variables defined in global.css — adapt automatically to dark/light theme
  const LEVEL_COLORS = ["var(--gh-0)", "var(--gh-1)", "var(--gh-2)", "var(--gh-3)", "var(--gh-4)"];
  const MONTH_NAMES = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  const DAY_LABELS = ["", "Mon", "", "Wed", "", "Fri", ""];

  async function fetchContributions(year) {
    try {
      const res = await fetch(
        `https://github-contributions-api.jogruber.de/v4/${username}?y=${year}`
      );
      if (!res.ok) return [];
      const data = await res.json();
      return data.contributions ?? [];
    } catch {
      return [];
    }
  }

  function buildCalendar(year, contributions) {
    const dateMap = new Map(contributions.map((c) => [c.date, c]));
    let current = new Date(Date.UTC(year, 0, 1));
    current = new Date(current.getTime() - current.getUTCDay() * 86400000);
    const end = new Date(Date.UTC(year, 11, 31));
    const weeks = [];

    while (current <= end) {
      const week = [];
      for (let d = 0; d < 7; d++) {
        const dateStr = current.toISOString().split("T")[0];
        const inYear = current.getUTCFullYear() === year;
        const contrib = dateMap.get(dateStr);
        week.push({
          date: dateStr,
          level: inYear ? (contrib?.level ?? 0) : -1,
          count: inYear ? (contrib?.count ?? 0) : 0,
          inYear,
        });
        current = new Date(current.getTime() + 86400000);
      }
      weeks.push(week);
    }
    return weeks;
  }

  function getMonthLabels(weeks) {
    const labels = new Array(weeks.length).fill("");
    let lastMonth = -1;
    weeks.forEach((week, i) => {
      for (const day of week) {
        if (day.inYear) {
          const month = new Date(day.date + "T00:00:00Z").getUTCMonth();
          if (month !== lastMonth) {
            labels[i] = MONTH_NAMES[month];
            lastMonth = month;
          }
          break;
        }
      }
    });
    return labels;
  }

  function renderYear(year, weeks, monthLabels) {
    const card = document.createElement("div");
    card.className = "bg-white dark:bg-gray-900 border border-transparent dark:border-gray-800 p-4 sm:p-6 rounded-xl shadow-md hover:shadow-lg dark:shadow-none dark:hover:border-gray-700 transition-all";

    // Year heading
    const heading = document.createElement("div");
    heading.className = "mb-4";
    const link = document.createElement("a");
    link.href = `https://github.com/${username}?tab=overview&from=${year}-01-01&to=${year}-12-31`;
    link.target = "_blank";
    link.rel = "noopener noreferrer";
    link.className = "text-2xl sm:text-3xl font-semibold text-gray-800 dark:text-gray-200 hover:underline";
    link.textContent = year;
    heading.appendChild(link);
    card.appendChild(heading);

    // Heatmap container
    const scrollWrap = document.createElement("div");
    scrollWrap.className = "overflow-x-auto";

    const grid = document.createElement("div");
    grid.style.cssText = "display: inline-flex; flex-direction: column; gap: 2px; min-width: max-content;";

    // Month labels row
    const monthRow = document.createElement("div");
    monthRow.style.cssText = "display: flex; gap: 2px; padding-left: 26px;";
    monthLabels.forEach((label) => {
      const m = document.createElement("div");
      m.style.cssText = "width: 11px; font-size: 10px; color: #6b7280; overflow: visible; white-space: nowrap; line-height: 1.2;";
      m.textContent = label;
      monthRow.appendChild(m);
    });
    grid.appendChild(monthRow);

    // Grid: day labels + week columns
    const body = document.createElement("div");
    body.style.cssText = "display: flex; gap: 2px;";

    // Day labels column
    const dayCol = document.createElement("div");
    dayCol.style.cssText = "display: flex; flex-direction: column; gap: 2px; margin-right: 4px;";
    DAY_LABELS.forEach((label) => {
      const d = document.createElement("div");
      d.style.cssText = "width: 22px; height: 11px; font-size: 9px; color: #6b7280; display: flex; align-items: center;";
      d.textContent = label;
      dayCol.appendChild(d);
    });
    body.appendChild(dayCol);

    // Week columns
    weeks.forEach((week) => {
      const col = document.createElement("div");
      col.style.cssText = "display: flex; flex-direction: column; gap: 2px;";
      week.forEach((day) => {
        const cell = document.createElement("div");
        const bg = day.level < 0 ? "transparent" : LEVEL_COLORS[day.level];
        cell.style.cssText = `width: 11px; height: 11px; border-radius: 2px; background-color: ${bg};`;
        if (day.inYear) {
          cell.title = `${day.date}: ${day.count} contribution${day.count !== 1 ? "s" : ""}`;
        }
        col.appendChild(cell);
      });
      body.appendChild(col);
    });

    grid.appendChild(body);
    scrollWrap.appendChild(grid);
    card.appendChild(scrollWrap);

    // Legend
    const legend = document.createElement("div");
    legend.style.cssText = "display: flex; align-items: center; justify-content: flex-end; margin-top: 8px; gap: 4px; font-size: 11px; color: #6b7280;";
    const lessSpan = document.createElement("span");
    lessSpan.textContent = "Less";
    legend.appendChild(lessSpan);
    LEVEL_COLORS.forEach((color) => {
      const box = document.createElement("div");
      box.style.cssText = `width: 11px; height: 11px; border-radius: 2px; background-color: ${color};`;
      legend.appendChild(box);
    });
    const moreSpan = document.createElement("span");
    moreSpan.textContent = "More";
    legend.appendChild(moreSpan);
    card.appendChild(legend);

    return card;
  }

  async function init() {
    const container = document.getElementById("github-graphs");
    if (!container) return;

    const currentYear = new Date().getFullYear();
    const years = Array.from(
      { length: currentYear - START_YEAR + 1 },
      (_, i) => START_YEAR + i
    );

    const results = await Promise.all(
      years.map(async (year) => {
        const contributions = await fetchContributions(year);
        const weeks = buildCalendar(year, contributions);
        const monthLabels = getMonthLabels(weeks);
        return { year, contributions, weeks, monthLabels };
      })
    );

    container.innerHTML = "";

    // API down or returned nothing — link to the profile instead of a blank section
    if (results.every((r) => r.contributions.length === 0)) {
      const fallback = document.createElement("div");
      fallback.className =
        "flex flex-col items-center justify-center py-16 gap-3 text-gray-500 dark:text-gray-400";
      const msg = document.createElement("p");
      msg.textContent = "Couldn't load the contribution graphs right now.";
      const profileLink = document.createElement("a");
      profileLink.href = `https://github.com/${username}`;
      profileLink.target = "_blank";
      profileLink.rel = "noopener noreferrer";
      profileLink.className = "font-medium hover:underline";
      profileLink.style.color = "var(--accent)";
      profileLink.textContent = `View my activity on GitHub →`;
      fallback.append(msg, profileLink);
      container.appendChild(fallback);
      return;
    }

    results.forEach(({ year, weeks, monthLabels }) => {
      container.appendChild(renderYear(year, weeks, monthLabels));
    });
  }

  // Defer the API calls until the section is near the viewport
  const section = document.getElementById("github");
  if (section && "IntersectionObserver" in window) {
    const lazy = new IntersectionObserver(
      (entries, obs) => {
        if (entries.some((e) => e.isIntersecting)) {
          obs.disconnect();
          init();
        }
      },
      { rootMargin: "600px 0px" }
    );
    lazy.observe(section);
  } else {
    init();
  }
</script>
