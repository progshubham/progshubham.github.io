---
import { siteConfig } from "../config";

const username = siteConfig.social.github.split("/").pop() ?? "progshubham";

const LEVEL_COLORS = ["#ebedf0", "#9be9a8", "#40c463", "#30a14e", "#216e39"];
const MONTH_NAMES = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];
// GitHub graph: Sun=row0, Mon=row1, ..., Sat=row6 — only label Mon/Wed/Fri
const DAY_LABELS = ["", "Mon", "", "Wed", "", "Fri", ""];

type Contribution = { date: string; count: number; level: number };
type CalendarDay = { date: string; level: number; count: number; inYear: boolean };

async function fetchContributions(year: number): Promise<Contribution[]> {
  try {
    const res = await fetch(
      `https://github-contributions-api.jogruber.de/v4/${username}?y=${year}`
    );
    if (!res.ok) return [];
    const data = await res.json();
    return (data.contributions ?? []) as Contribution[];
  } catch {
    return [];
  }
}

function buildCalendar(year: number, contributions: Contribution[]): CalendarDay[][] {
  const dateMap = new Map(contributions.map((c) => [c.date, c]));

  // Start from the Sunday on or before Jan 1
  let current = new Date(Date.UTC(year, 0, 1));
  current = new Date(current.getTime() - current.getUTCDay() * 86400000);

  const end = new Date(Date.UTC(year, 11, 31));
  const weeks: CalendarDay[][] = [];

  while (current <= end) {
    const week: CalendarDay[] = [];
    for (let d = 0; d < 7; d++) {
      const dateStr = current.toISOString().split("T")[0];
      const inYear = current.getUTCFullYear() === year;
      const contrib = dateMap.get(dateStr);
      week.push({
        date: dateStr,
        level: inYear ? (contrib?.level ?? 0) : -1,
        count: inYear ? (contrib?.count ?? 0) : 0,
        inYear,
      });
      current = new Date(current.getTime() + 86400000);
    }
    weeks.push(week);
  }
  return weeks;
}

function getMonthLabelRow(weeks: CalendarDay[][]): string[] {
  const labels: string[] = new Array(weeks.length).fill("");
  let lastMonth = -1;
  weeks.forEach((week, i) => {
    for (const day of week) {
      if (day.inYear) {
        const month = new Date(day.date + "T00:00:00Z").getUTCMonth();
        if (month !== lastMonth) {
          labels[i] = MONTH_NAMES[month];
          lastMonth = month;
        }
        break;
      }
    }
  });
  return labels;
}

const currentYear = new Date().getFullYear();
const START_YEAR = 2023;
const years = Array.from({ length: currentYear - START_YEAR + 1 }, (_, i) => START_YEAR + i);

const calendarData = await Promise.all(
  years.map(async (year) => {
    const contributions = await fetchContributions(year);
    const weeks = buildCalendar(year, contributions);
    const monthLabels = getMonthLabelRow(weeks);
    const total = contributions.reduce((s, c) => s + c.count, 0);
    return { year, weeks, monthLabels, total };
  })
);
---

<section
  id="github"
  aria-label="GitHub Contributions by Shubham Kumar Rohit"
  class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50"
>
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-4xl xl:text-5xl font-bold text-gray-900">
          GitHub Contributions
        </h2>
        <div
          class="w-[75px] h-[5px] mt-2 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        ></div>
        <p class="mt-4 text-gray-600 text-sm leading-relaxed">
          Year-by-year view of my open-source and private code activity on
          GitHub — commits, pull requests, reviews, and issue contributions.
        </p>
      </div>

      <div class="lg:col-span-8 space-y-10">
        {calendarData.map(({ year, weeks, monthLabels, total }) => (
          <div class="bg-white p-4 sm:p-6 rounded-xl shadow-md hover:shadow-lg transition-all">
            <div class="mb-4">
              <a
                href={`https://github.com/${username}?tab=overview&from=${year}-01-01&to=${year}-12-31`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`View ${siteConfig.name}'s GitHub contributions for ${year}`}
                class="text-2xl sm:text-3xl font-semibold text-gray-800 hover:underline"
              >
                {year}
                {/* visually hidden total for screen readers & crawlers */}
                <span class="sr-only"> — {total.toLocaleString()} contributions</span>
              </a>
            </div>

            <div
              class="overflow-x-auto"
              role="img"
              aria-label={`GitHub contribution heatmap for ${year}: ${total.toLocaleString()} total contributions by ${siteConfig.name}`}
            >
              <div style="display: inline-flex; flex-direction: column; gap: 2px; min-width: max-content;">
                {/* Month labels row */}
                <div style="display: flex; gap: 2px; padding-left: 26px;" aria-hidden="true">
                  {monthLabels.map((label) => (
                    <div style="width: 11px; font-size: 10px; color: #6b7280; overflow: visible; white-space: nowrap; line-height: 1.2;">
                      {label}
                    </div>
                  ))}
                </div>

                {/* Grid: day labels + week columns */}
                <div style="display: flex; gap: 2px;">
                  {/* Day labels */}
                  <div style="display: flex; flex-direction: column; gap: 2px; margin-right: 4px;" aria-hidden="true">
                    {DAY_LABELS.map((label) => (
                      <div style="width: 22px; height: 11px; font-size: 9px; color: #6b7280; display: flex; align-items: center;">
                        {label}
                      </div>
                    ))}
                  </div>

                  {/* Week columns */}
                  {weeks.map((week) => (
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                      {week.map((day) => (
                        <div
                          style={`width: 11px; height: 11px; border-radius: 2px; background-color: ${
                            day.level < 0 ? "transparent" : LEVEL_COLORS[day.level]
                          };`}
                          title={
                            day.inYear
                              ? `${day.date}: ${day.count} contribution${day.count !== 1 ? "s" : ""}`
                              : undefined
                          }
                        />
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            </div>

            {/* Legend */}
            <div
              style="display: flex; align-items: center; justify-content: flex-end; margin-top: 8px; gap: 4px; font-size: 11px; color: #6b7280;"
              aria-hidden="true"
            >
              <span>Less</span>
              {LEVEL_COLORS.map((color) => (
                <div style={`width: 11px; height: 11px; border-radius: 2px; background-color: ${color};`} />
              ))}
              <span>More</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
